---
import TagPills from "./TagPills.astro";

const { project } = Astro.props as { project: any };
---

<a href={`/projects/${project.slug}`} style="color: inherit; text-decoration:none;">
  <div class="card" style="overflow:hidden;">
    {project.data.teaser ? (
      <img src={project.data.teaser} alt="" style="width:100%; height:160px; object-fit:cover; display:block;" />
    ) : null}
    <div style="padding: 16px;">
      <div style="font-weight: 780; font-size: 16px;">{project.data.title}</div>
      {project.data.tagline ? <div style="color: var(--muted); margin-top: 6px;">{project.data.tagline}</div> : null}
      {project.data.tags?.length ? <TagPills tags={project.data.tags} /> : null}
      <div style="margin-top: 6px; color: var(--muted); font-size: 13px;">Open project →</div>
    </div>
  </div>
</a>