---
import LinkBar from "./LinkBar.astro";

const { item, html } = Astro.props as { item: any; html: string };
const bg = item.data.backgroundImage ?? "/images/placeholder-work-bg.jpg";
---

<section class="card" style="overflow:hidden;">
  <div
    style={`
      background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.25)), url(${bg});
      background-size: cover;
      background-position: center;
      padding: 18px;
      color: white;
    `}
  >
    <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap;">
      <div style="font-weight: 800; font-size: 18px;">
        {item.data.role} • {item.data.company}
      </div>
      <div style="opacity: 0.9; font-weight: 650;">
        {item.data.start} – {item.data.end}
      </div>
    </div>
    {item.data.location ? <div style="opacity:0.9; margin-top: 6px;">{item.data.location}</div> : null}
    {item.data.impact ? (
      <div style="margin-top: 8px; max-width: 90ch; opacity: 0.95;">
        <span style="font-weight: 750;">Impact:</span> {item.data.impact}
      </div>
    ) : null}
  </div>
  <div style="padding: 16px;">
    {item.data.highlights?.length ? (
      <ul style="margin: 0 0 12px 0; padding-left: 18px;">
        {item.data.highlights.map((h: string) => <li>{h}</li>)}
      </ul>
    ) : null}

    <div class="prose" set:html={html} />
    <LinkBar links={item.data.links} />
  </div>
</section>

<style>
  .prose :global(p) { margin: 0 0 10px 0; }
  .prose :global(ul) { margin: 0; padding-left: 18px; }
</style>