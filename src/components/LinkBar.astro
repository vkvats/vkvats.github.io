---
const { links } = Astro.props as {
  links?: Record<string, string>;
};

const ordered = [
  ["project", "Project"],
  ["pdf", "PDF"],
  ["arxiv", "arXiv"],
  ["code", "Code"],
  ["bibtex", "BibTeX"],
  ["video", "Video"],
  ["poster", "Poster"],
  ["supplement", "Supplement"],
  ["dataset", "Dataset"],
  ["doi", "DOI"],
  ["demo", "Demo"],
  ["company", "Company"],
  ["blog", "Blog"],
  ["repo", "Repo"],
  ["paper", "Paper"],
  ["updated", "Journal Version"]
] as const;

function isExternal(url: string) {
  return /^https?:\/\//.test(url);
}
---

<div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 10px;">
  {ordered.map(([key, label]) => {
    const url = links?.[key];
    if (!url) return null;
    const external = isExternal(url) || url.startsWith("mailto:");
    return (
      <a
        class="btn"
        href={url}
        target={external && !url.startsWith("mailto:") ? "_blank" : undefined}
        rel={external && !url.startsWith("mailto:") ? "noopener noreferrer" : undefined}
      >
        {label}
      </a>
    );
  })}
</div>