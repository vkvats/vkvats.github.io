---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import NewsList from "../components/NewsList.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PubCard from "../components/PubCard.astro";

const news = (await getCollection("news")).sort((a,b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 5);
const projects = (await getCollection("projects")).slice(0, 3);
const selectedPubs = (await getCollection("publications"))
  .filter(p => p.data.selected)
  .sort((a,b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<BaseLayout title="Home" bodyClass="home">
  <section class="card" style="padding: 18px;">
    <div style="font-size: 30px; font-weight: 850; letter-spacing: -0.02em;">
      Computer vision for large-scale visual understanding, novel-view synthesis and 3D reconstruction
    </div>
    <p style="color: var(--muted); font-size: 16px; margin-top: 10px; max-width: 72ch;">
      My research involves developing and applying computer vision algorithms that understand, analyze, and organize large-scale datasets of images and video using deep learning-based techniques. My recent focus has been on creating computer vision algorithms that can generate and synthesize 3D models of visual scenes from 2D images, using techniques such as multi-view stereo, stable diffusion, and other deep learning models
    </p>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top: 12px;">
      <a class="btn btn-primary" href="/publications">View publications</a>
      <a class="btn" href="/projects">View projects</a>
      <a class="btn" href="/work">Work / internships</a>
    </div>
  </section>

  <div style="height: 16px;"></div>

  <section class="grid grid-2">
    <div class="card" style="padding: 16px;">
      <h2 style="margin:0 0 10px 0;">Research pillars</h2>
      <ul style="margin:0; padding-left: 18px; color: var(--muted);">
        <li>3D Reconstruction, Multi-View Stereo</li>
        <li>Splatting, Novel-view Synthesis</li>
        <li>Generative Modeling for Geospatial images</li>
        <li>Satellite Imagery Understanding</li>
        <li>Geometry Reasoning in 3D</li>
        <li>Deep Leraning core</li>
      </ul>
      <div style="margin-top: 10px;">
        <a class="btn" href="/research">Explore research →</a>
      </div>
    </div>

    <div class="card" style="padding: 16px;">
      <h2 style="margin:0 0 10px 0;">Recent news</h2>
      <NewsList items={news} />
    </div>
  </section>

  <hr class="sep" />

  <h2 style="margin: 0 0 12px 0;">Featured projects</h2>
  <div class="grid grid-3">
    {projects.map(p => <ProjectCard project={p} />)}
  </div>

  <div style="height: 18px;"></div>

  <h2 style="margin: 0 0 12px 0;">Selected publications</h2>
  <div class="grid" style="gap: 12px;">
    {selectedPubs.map(p => <PubCard pub={p} />)}
  </div>

  <div style="margin-top: 12px;">
    <a class="btn" href="/publications">All publications →</a>
  </div>
</BaseLayout>