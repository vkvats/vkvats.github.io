---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkPanel from "../../components/WorkPanel.astro";
import { getCollection } from "astro:content";

const items = (await getCollection("work"))
  .filter(w => !w.slug.startsWith("_"))
  .sort((a,b) => (b.data.end || "").localeCompare(a.data.end || ""));
---

<BaseLayout title="Work">
  <h1 style="margin-top:0;">Work / Internships</h1>
  <p style="color: var(--muted); max-width: 72ch;">
    Work Experience
  </p>

  <div class="grid" style="gap: 14px;">
    {await Promise.all(items.map(async (it) => {
      const rendered = await it.render();
      return <WorkPanel item={it} html={rendered.html} />;
    }))}
  </div>
</BaseLayout>